{
    "name": "aiarmada/filament-signals",
    "description": "Filament admin dashboard for AIArmada Signals analytics",
    "license": "MIT",
    "type": "library",
    "keywords": [
        "laravel",
        "filament",
        "signals",
        "analytics",
        "product-analytics"
    ],
    "authors": [
        {
            "name": "AIArmada",
            "email": "dev@aiarmada.com"
        }
    ],
    "require": {
        "aiarmada/commerce-support": "self.version",
        "aiarmada/signals": "self.version",
        "filament/filament": "^5.6.5",
        "php": "^8.4"
    },
    "autoload": {
        "psr-4": {
            "AIArmada\\FilamentSignals\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "AIArmada\\FilamentSignals\\FilamentSignalsServiceProvider"
            ]
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
